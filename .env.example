# CodexClaw local Codex CLI adapter
#
# The dashboard server runs Codex CLI locally through `codex exec --json`.
# Keep machine-specific values here and do not commit real secrets.

CODEX_CLI_COMMAND=codex
CODEX_CLI_SANDBOX=read-only

# Optional: run Codex against a specific workspace instead of the app process cwd.
# CODEX_CLI_WORKDIR=C:/path/to/project

# Optional: persist CodexClaw session history somewhere explicit.
# CODEX_CLAW_STATE_DIR=C:/path/to/codex-claw-state
